    "@heroui/react": "^2.8.10",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.2",
    "openai": "^6.27.0",
    "pixi.js": "^8.17.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
