{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "skipLibCheck": true,
    "baseUrl": "."
  },
  "include": [
    "electron.vite.config.ts",
    "playwright.config.ts",
    "vitest.config.ts",
    "eslint.config.mjs",
    "scripts/**/*.ts"
  ]
}
